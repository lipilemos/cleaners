{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022", "dom"],
    "module": "Node16",
    "moduleResolution": "node16",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "noUncheckedSideEffectImports": false,
    "types": ["*"],
    "paths": {
      "@cleaners/ui": ["./libs/shared/ui/src/index.ts"],
      "@cleaners/util": ["./libs/shared/util/src/index.ts"],
      "@cleaners/auth": ["./libs/shared/auth/src/index.ts"],
      "@cleaners/data-access": ["./libs/shared/data-access/src/index.ts"],
      "@cleaners/i18n": ["./libs/shared/i18n/src/index.ts"],
      "@cleaners/models": ["./libs/shared/models/src/index.ts"]
    }
  }
}
